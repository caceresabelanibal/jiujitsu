# Plantilla de configuración para PRODUCCIÓN.
# En el server, copiala una sola vez a un archivo llamado .env:
#     cp .env.prod.example .env
#
# Con la línea COMPOSE_FILE de abajo, el comando corto
#     docker compose up -d --build
# ya usa los tres archivos (base + prod + tls) automáticamente, sin escribir -f.
# El archivo .env NO se sube a git (está en .gitignore).

COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml:docker-compose.tls.yml

# Secretos / config (cambiá lo que quieras):
CRON_KEY=cambiame-por-una-cadena-larga-aleatoria
ADMIN_EMAIL=admin@taninzu.com
ADMIN_PASSWORD=Taninzu2026!

# Torneos demo (1 = crearlos; 0 = no). Cuando no los quieras más, poné 0.
SEED_DEMO=1
